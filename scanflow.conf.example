[general]
# AI provider: claude, openai, or ollama
provider = claude
# model (optional for claude/openai, required for ollama)
# model = claude-sonnet-4-20250514
# model = gpt-4o

[claude]
# API key here or set ANTHROPIC_API_KEY env variable
# Env variable takes precedence over config
api_key = sk-ant-...

[openai]
# API key here or set OPENAI_API_KEY env variable
# Env variable takes precedence over config
api_key = sk-...

# Ollama instances - multiple supported, tried by priority (lowest first)
# Use [ollama:name] for named instances, or [ollama] for a single one

# [ollama:server1]
# url = http://192.168.1.100:11434
# model = gemma3:27b
# priority = 10
# api_key = ...  (optional, for authenticated instances)

# [ollama:server2]
# url = http://192.168.1.101:11434
# model = qwen3:14b
# priority = 20

[sort]
# Default source and target directories for 'scanflow sort'
# source = /scans/output
# target = /documents
# Number of direct folder suggestions (default: 5)
# max_suggestions = 5
# Number of parent category suggestions (default: 5)
# max_parent_suggestions = 5

# One [watch:name] section per directory set to monitor
[watch:user1]
single_dir = /scans/user1/single
multi_dir = /scans/user1/multi
output_dir = /scans/user1/output

# [watch:user2]
# single_dir = /scans/user2/single
# multi_dir = /scans/user2/multi
# output_dir = /scans/user2/output
