#!/usr/bin/env python3
"""Scanflow: PDF processing toolkit — watch, ocr, rename, sort."""

import argparse
import sys

from cli import watch, ocr, rename, sort


def main():
    parser = argparse.ArgumentParser(
        prog="scanflow",
        description="scanflow — PDF processing toolkit",
    )
    subparsers = parser.add_subparsers(dest="command")

    watch.setup_parser(subparsers)
    ocr.setup_parser(subparsers)
    rename.setup_parser(subparsers)
    sort.setup_parser(subparsers)

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nAborted.")
        sys.exit(130)
